{
  "realm": "openfmr",
  "enabled": true,
  "displayName": "OpenFMR Health Information Exchange",
  "displayNameHtml": "<strong>OpenFMR</strong> Health Information Exchange",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "roles": {
    "realm": [
      {
        "name": "doctor",
        "description": "Licensed medical practitioner — can read and write clinical records."
      },
      {
        "name": "nurse",
        "description": "Nursing staff — can read clinical records and update observations."
      },
      {
        "name": "admin",
        "description": "System administrator — full platform management access."
      },
      {
        "name": "data_steward",
        "description": "Data steward — can review and resolve conflict records in the Admin UI."
      }
    ]
  },
  "clients": [
    {
      "clientId": "openfmr-smart-client",
      "name": "OpenFMR SMART Client",
      "description": "Public OIDC client configured for SMART-on-FHIR authorization flows. Used by EMR applications and clinical frontends to obtain OAuth 2.0 access tokens.",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost/*",
        "http://localhost:8080/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "*"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email"
      ],
      "optionalClientScopes": [
        "offline_access",
        "roles",
        "launch",
        "fhirUser",
        "patient/*.read",
        "patient/*.write",
        "launch/patient",
        "user/Patient.read",
        "user/Patient.write",
        "user/Encounter.write",
        "user/Claim.read"
      ],
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "false",
        "oidc.ciba.grant.enabled": "false",
        "post.logout.redirect.uris": "http://localhost/*"
      }
    }
  ],
  "clientScopes": [
    {
      "name": "launch",
      "description": "SMART on FHIR launch scope",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "fhirUser",
      "description": "Access to the logged-in user's FHIR resource",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      },
      "protocolMappers": [
        {
          "name": "fhirUser mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "fhirUser",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "fhirUser",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "name": "patient/*.read",
      "description": "Read access to all FHIR resources in patient context",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "patient/*.write",
      "description": "Write access to all FHIR resources in patient context",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "launch/patient",
      "description": "Standalone SMART launch with patient context",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "user/Patient.read",
      "description": "Read Patient resources as user",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
      "name": "user/Patient.write",
      "description": "Write Patient resources as user",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "false"
      }
    },
    {
