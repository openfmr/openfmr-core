# =============================================================================
# OpenFMR Core — Environment Variables
# =============================================================================
# Copy this file to .env and customise as needed:
#   cp .env.example .env
#
# All values below are sensible development defaults. Change them for
# staging / production deployments.
# =============================================================================

# ---------------------------------------------------------------------------
# MongoDB Credentials
# ---------------------------------------------------------------------------
MONGO_USERNAME=root
MONGO_PASSWORD=openfmr

# ---------------------------------------------------------------------------
# OpenHIM Root User (default admin account)
# ---------------------------------------------------------------------------
OPENHIM_ROOT_EMAIL=root@openhim.org
OPENHIM_ROOT_PASSWORD=openhim-password

# ---------------------------------------------------------------------------
# Port Mappings (host:container implied in docker-compose.yml)
# ---------------------------------------------------------------------------
# HTTP listener for inbound FHIR traffic
OPENHIM_HTTP_PORT=8080

# HTTPS listener for inbound FHIR traffic (TLS)
OPENHIM_HTTPS_PORT=5001

# OpenHIM Admin / Management API
OPENHIM_API_PORT=5000

# OpenHIM Console (web admin dashboard)
OPENHIM_CONSOLE_PORT=80
